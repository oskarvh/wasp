menu "wasp"

config WASP_AGENT_PORT
	int "TCP port the agent listens on"
	default 4242

config WASP_WAMR_HEAP_POOL_SIZE
	int "Static heap pool handed to WAMR (bytes)"
	default 90112
	help
	  All WASM module memory (module structures, linear memory, exec
	  stacks) is allocated from this pool. A standard clang-built module
	  needs one contiguous 64 KiB WASM page for linear memory plus
	  runtime overhead, so this must comfortably exceed 64 KiB. Tune per
	  board in boards/<board>.conf.

config WASP_MAX_MODULE_SIZE
	int "Maximum accepted .wasm module size (bytes)"
	default 32768

config WASP_WASM_STACK_SIZE
	int "WASM execution stack size (bytes, from the WAMR pool)"
	default 4096

config WASP_WASM_HEAP_SIZE
	int "Per-module-instance app heap size (bytes)"
	default 4096
	help
	  Backs malloc() inside the WASM module (libc-builtin). Carved from
	  the module's memory space at instantiation time.

config WASP_WIFI_SSID
	string "WiFi SSID (boards with WiFi only)"
	default ""
	help
	  Network the node joins before starting DHCP. Do NOT put real
	  credentials in committed files: create app/wifi_credentials.conf
	  (gitignored, merged automatically — see README) instead.

config WASP_WIFI_PSK
	string "WiFi passphrase (WPA2-PSK; empty = open network)"
	default ""

config WASP_RPC_TIMEOUT_MS
	int "Remote-memory RPC timeout (ms)"
	default 5000
	help
	  How long a wasp.* host function waits for the coordinator to
	  answer a MEM_READ/MEM_WRITE/LOCK/... request before giving up and
	  raising a WASM exception on the calling module.

config WASP_STATUS_LED
	bool "Drive a status LED (needs an led0 devicetree alias)"
	default y
	help
	  Blink patterns show network state at a glance; the IDENTIFY
	  command strobes it so a specific board can be located. No-op on
	  boards without an led0 alias.

config WASP_ANNOUNCE_PORT
	int "UDP port for discovery broadcasts"
	default 4243

config WASP_ANNOUNCE_INTERVAL
	int "Seconds between ANNOUNCE broadcasts"
	default 5

config WASP_NET_THREAD_STACK_SIZE
	int "Network handler thread stack size"
	default 4096

config WASP_AGENT_THREAD_STACK_SIZE
	int "Agent thread stack size"
	default 4096

config WASP_EXEC_THREAD_STACK_SIZE
	int "WASM executor thread stack size"
	default 8192

endmenu

source "Kconfig.zephyr"
